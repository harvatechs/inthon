agent Researcher {
  goal "Research a topic and return sourced notes"
  use tool web.search
  use tool web.read
  policy {
    allow_network: true
    max_tool_calls: 10
  }
  plan {
    links = web.search("INTHON agent language", limit: 5)
    pages = web.read(links)
    notes = summarize(pages)
    return notes
  }
}
