// examples/deep_researcher.inth
// A production-grade Inthon application performing web search, deep crawling, and semantic memory caching.

use py.re as re
use py.examples.text_utils as utils
use tool web.search
use tool web.read

fn perform_research(query: str) {
    let is_valid = len(query) > 2
    if not is_valid {
        print("Error: Research query is too short. Please enter a valid topic.")
        return None
    }

    print("Spawning Deep Researcher Agent...")

    agent DeepResearcher {
        goal "Perform a multi-site web search, crawl pages, extract summaries, and cache findings."

        policy {
            allow_network: true
            max_tool_calls: 10
            max_cost_usd: 0.10
        }

        plan {
            // Check semantic memory first
            print("Searching semantic memory for cached report...")
            let cached_report = recall "ConsolidatedResearch" from deep_research_cache

            if cached_report {
                print("Cache Hit! Found existing report in semantic memory:")
                return cached_report
            }

            print("Cache Miss. Initiating web search...")
            let results = web.search(query, limit: 2)

            print("Iterating over search results and scraping text...")
            let crawled_text = ""
            for result in results {
                let url = result.url
                print("Crawling: " + url)
                let html = web.read(url)
                let cleaned = utils.clean_html(html)
                let summary = utils.summarize_text(cleaned)
                crawled_text = crawled_text + "\nSource: " + url + "\nSummary: " + summary + "\n"
            }

            print("Caching synthesized report to semantic memory...")
            remember crawled_text in deep_research_cache
            return crawled_text
        }
    }
}

let report = perform_research("Inthon programming language")
print("Research Report generated successfully.")
report
