// examples/lead_researcher.inth
// A production-ready Inthon application demonstrating Lead Research with Memory and Approvals.

use py.re as re
use py.examples.text_utils as utils
use tool web.search

fn handle_lead_research(company_name: str) {
    print("Spawning Lead Researcher Agent for " + company_name + "...")

    agent LeadResearcher {
        goal "Perform real-time web research, persist findings, and enforce verification gates."

        policy {
            allow_network: true
            max_tool_calls: 5
            max_cost_usd: 0.05
        }

        plan {
            // Trigger approval verification for specific companies
            let is_openai = re.search("OpenAI", company_name)
            let is_microsoft = re.search("Microsoft", company_name)

            if is_openai or is_microsoft {
                print("Flagged: Premium report verification gate triggered.")
                approve stripe.charge before make_payment
            }

            print("Initiating search for company details...")
            let results = web.search(company_name + " company overview and metrics", limit: 3)
            
            print("Storing research summary in lead memory...")
            remember results in lead_db
            
            return results
        }
    }
}

let lead_data = handle_lead_research("OpenAI")
print("Lead Research Complete.")
lead_data
