// examples/web_summarizer.inth
// A production-ready Inthon application demonstrating real-time Web Scraping & Summarization with memory.

use py.re as re
use py.examples.text_utils as utils
use tool web.read

fn handle_summarize(url: str) {
    let is_valid_url = re.search("^https?://", url)
    if not is_valid_url {
        print("Error: Please enter a valid URL starting with http:// or https://")
        return None
    }

    print("Spawning Web Summarizer Agent...")

    agent WebSummarizer {
        goal "Fetch webpage content, strip HTML tags, and index findings in semantic memory."

        policy {
            allow_network: true
            max_tool_calls: 3
            max_cost_usd: 0.05
        }

        plan {
            print("Fetching webpage content...")
            let html = web.read(url)
            
            print("Cleaning HTML content...")
            let cleaned = utils.clean_html(html)
            
            print("Generating abstract summary...")
            let summary = utils.summarize_text(cleaned)
            
            print("Caching summary findings in semantic cache...")
            remember summary in web_cache
            
            let recalled = recall "Inthon" from web_cache
            return recalled
        }
    }
}

let result = handle_summarize("https://en.wikipedia.org/wiki/Inthon")
print("Web Summarizer Execution Completed.")
result
