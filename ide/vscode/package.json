{
    "name": "inthon",
    "displayName": "INTHON Language Support",
    "description": "Syntax highlighting and file icon support for the INTHON programming language.",
    "version": "0.2.0",
    "publisher": "harvadeeplabs",
    "main": "./extension.js",
    "activationEvents": [
        "onLanguage:inthon"
    ],
    "engines": {
        "vscode": "^1.60.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/harvatechs/inthon"
    },
    "categories": [
        "Programming Languages"
    ],
    "icon": "images/inthon-icon.png",
    "contributes": {
        "languages": [
            {
                "id": "inthon",
                "aliases": [
                    "INTHON",
                    "inthon"
                ],
                "extensions": [
                    ".inth"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./images/inthon-icon.png",
                    "dark": "./images/inthon-icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "inthon",
                "scopeName": "source.inth",
                "path": "./syntaxes/inthon.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "inthon",
                "path": "./snippets/inthon.code-snippets"
            }
        ],
        "commands": [
            {
                "command": "inthon.run",
                "title": "Run INTHON Script",
                "category": "INTHON",
                "icon": "$(play)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "when": "resourceLangId == inthon",
                    "command": "inthon.run",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "when": "resourceLangId == inthon",
                    "command": "inthon.run",
                    "group": "navigation"
                }
            ]
        }
    }
}
