{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "INTHON",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.inth",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash.inth",
                    "begin": "//",
                    "end": "$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.inth",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.inth",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.inth",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.inth",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.inth",
                    "match": "\\b(return|if|else|for|while|break|continue|retry|catch|fail)\\b"
                },
                {
                    "name": "keyword.other.agent.inth",
                    "match": "\\b(agent|goal|plan|policy|observe|act|approve|before|remember|forget|recall|from|in|to|eval|guard|with|backoff|exponential|log|save|memory|trace|pay)\\b"
                },
                {
                    "name": "keyword.declaration.inth",
                    "match": "\\b(let|const|fn|use|tool|py|as|import)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.inth",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.none.inth",
                    "match": "\\bnone\\b"
                },
                {
                    "name": "constant.numeric.float.inth",
                    "match": "\\b\\d+\\.\\d*([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.inth",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.inth",
                    "match": "\\b(and|or|not)\\b"
                },
                {
                    "name": "keyword.operator.inth",
                    "match": "(\\+|\\-|\\*|\\/|%|\\*\\*|=|==|!=|<|<=|>|>=|->|\\|)"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.inth",
                    "match": "\\b(str|int|float|bool|bytes|any|list|dict|tuple)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.inth",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        }
    },
    "scopeName": "source.inth"
}
